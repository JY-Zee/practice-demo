{
  "name": "@demo/ui-vue",
  "version": "1.0.0",
  "private": true,
  "description": "Vue UI 组件库",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "dependencies": {
    "@demo/types": "workspace:*",
    "element-plus": "^2.5.7"
  },
  "devDependencies": {
    "@demo/tsconfig": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vue": "^3.4.19",
    "vue-tsc": "^1.8.27"
  }
}
