{
  "name": "@demo/types",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript 类型定义包",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@demo/tsconfig": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  }
}
