# pnpm 配置文件

# 严格模式:防止幽灵依赖(使用未在 package.json 中声明的包)
# 这能帮助你明确所有依赖关系
strict-peer-dependencies=false

# 提升模式:将所有依赖提升到根 node_modules
# false 表示使用隔离模式,每个包只能访问自己声明的依赖
hoist=false

# 公共提升模式:某些包需要提升(如 TypeScript)
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*typescript*

# 自动安装 peer dependencies
auto-install-peers=true

# 使用 shamefully-hoist 可以解决某些工具的兼容性问题
# 但会牺牲依赖隔离性,建议开发阶段保持 false
shamefully-hoist=false

# 锁定文件版本
lockfile=true
