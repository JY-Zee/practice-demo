{
  "name": "@demo/monorepo-root",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo 学习项目 - 企业级多包管理实践",
  "scripts": {
    "dev": "turbo run dev --filter=\"./packages/apps/*\"",
    "dev:web": "turbo run dev --filter=@demo/web-app",
    "dev:admin": "turbo run dev --filter=@demo/admin",
    "dev:mobile": "turbo run dev --filter=@demo/mobile-h5",
    "build": "turbo run build",
    "build:apps": "turbo run build --filter=\"./packages/apps/*\"",
    "build:libs": "turbo run build --filter=\"./packages/shared/*\"",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:dist": "pnpm -r exec rm -rf dist",
    "test": "turbo run test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "keywords": [
    "monorepo",
    "pnpm",
    "workspace",
    "react",
    "vue",
    "typescript"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.6.11",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^1.12.5",
    "typescript": "^5.3.3"
  }
}
