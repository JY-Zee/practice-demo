# ============================================================
# RAG 知识库系统 - 环境变量模板
# 复制为 .env 后填入实际值即可使用
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=kb_user
POSTGRES_PASSWORD=kb_password
POSTGRES_DB=kb_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---------- Qdrant ----------
QDRANT_HOST=qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=kb_documents

# ---------- Embedding ----------
# 必填：替换为真实密钥，不能保留模板值
EMBEDDING_API_KEY=sk-your-embedding-api-key
# 必填：填写你服务器可访问的 OpenAI 兼容网关地址
# 例如 DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
# 例如 SiliconFlow: https://api.siliconflow.cn/v1
EMBEDDING_API_BASE=
# 必填：填写与上面网关匹配的 embedding 模型名
EMBEDDING_MODEL=
# 必填：填写该模型实际输出的向量维度，并与 Qdrant 集合保持一致
EMBEDDING_DIMENSION=1536

# ---------- LLM ----------
LLM_API_KEY=sk-your-llm-api-key
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ---------- 文件存储 ----------
UPLOAD_DIR=/app/uploads

# ---------- 异步摄取 Worker ----------
INGESTION_QUEUE_PREFIX=rag-kb
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=20

# ---------- 后端服务 ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ---------- 前端服务 ----------
NEXT_PUBLIC_API_BASE=http://localhost:8000
